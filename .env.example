# ─────────────────────────────────────────────────────────────────────────────
# Alumni Influencer – environment configuration example
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Set to 'production' on a live server to hide error details from users.
CI_ENVIRONMENT = development

# The public URL where the app is served (include trailing slash).
app.baseURL = 'http://localhost/alumni_influencer_fixed/public/'

# ── Database ──────────────────────────────────────────────────────────────────
database.default.hostname = localhost
database.default.database = alumni_influencer
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port     = 3306

# ── Session ───────────────────────────────────────────────────────────────────
app.sessionDriver     = 'CodeIgniter\Session\Handlers\FileHandler'
app.sessionCookieName = 'ci_session'
# Session lifetime in seconds (7200 = 2 hours)
app.sessionExpiration = 7200
app.sessionSavePath   = WRITEPATH . 'session'

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used for: email verification, password reset, bid notifications, winner alerts.
# For local development you can use Mailtrap (https://mailtrap.io) or MailHog.

# Protocol: 'smtp' for SMTP server, 'mail' to use PHP mail() (not recommended in production)
EMAIL_PROTOCOL    = smtp

EMAIL_FROM_ADDRESS = no-reply@iit.ac.lk
EMAIL_FROM_NAME    = 'Alumni Influencer'

# SMTP server hostname (e.g. smtp.gmail.com, smtp.mailtrap.io)
EMAIL_SMTP_HOST   = smtp.mailtrap.io

# SMTP username
EMAIL_SMTP_USER   = your_smtp_username

# SMTP password
EMAIL_SMTP_PASS   = your_smtp_password

# SMTP port: 587 for STARTTLS, 465 for implicit SSL, 25 for unencrypted
EMAIL_SMTP_PORT   = 587

# Encryption: 'tls' for STARTTLS (port 587), 'ssl' for implicit SSL (port 465), '' for none
EMAIL_SMTP_CRYPTO = tls

# ── Cron Security ─────────────────────────────────────────────────────────────
# A long random secret shared between your server's cron job and this application.
# The cron job must send this value in the X-Cron-Secret HTTP header.
# Generate a strong secret with: php -r "echo bin2hex(random_bytes(32));"
# The /cron/pick-winner endpoint will return 403 if this header is missing or wrong.
CRON_SECRET = your_long_random_secret_here
